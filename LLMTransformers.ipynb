   "source": [
    "# 🏥 Scenario: Healthcare Chatbot for Patient Queries\n",
    "# A hospital is developing a chatbot to help patients ask questions about their health.\n",
    "# - A patient types:\n",
    "# “Deep learning models are powerful” (or in practice, something like “I have chest pain and shortness of breath”).\n",
    "# - The chatbot uses the BERT tokenizer to break the sentence into tokens:\n",
    "from transformers import AutoTokenizer\n",
    "\n",
    "# 1. Load the pre-trained BERT tokenizer\n",
    "# \"uncased\" means it will treat \"Pain\" and \"pain\" the same way\n",
    "tokenizer = AutoTokenizer.from_pretrained(\"bert-base-uncased\")\n",
    "\n",
    "# 2. Define the patient's query\n",
    "patient_query = \"I have chest pain and shortness of breath\"\n",
    "\n",
    "# 3. Break the sentence into tokens (WordPieces)\n",
    "# This handles medical terms by splitting them if they aren't in the vocabulary\n",
    "tokens = tokenizer.tokenize(patient_query)\n",
    "\n",
    "# 4. Convert tokens to numerical IDs\n",
    "# These IDs are what the actual BERT model \"sees\" and processes\n",
    "token_ids = tokenizer.convert_tokens_to_ids(tokens)\n",
    "\n",
    "# Output the results\n",
    "print(f\"Patient Query: {patient_query}\")\n",
    "print(f\"Tokens: {tokens}\")\n",
    "print(f\"Token IDs: {token_ids}\")\n"
   ]
  },
